{"id":3,"name":"女媧","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"女媧 移動","direction":2,"pattern":0,"characterIndex":0},"list":[{"code":101,"indent":0,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":0,"parameters":["有事情找我？"]},{"code":101,"indent":0,"parameters":["蛋蛋 頭像",0,0,2,"豬腳"]},{"code":401,"indent":0,"parameters":["我想聽故事"]},{"code":101,"indent":0,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":0,"parameters":["你要聽什麼呢?"]},{"code":102,"indent":0,"parameters":[["黃帝","蚩尤","伏羲氏","神農氏","女媧","不用了"],5,0,2,0]},{"code":402,"indent":0,"parameters":[0,"黃帝"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["黃帝是我們村落的領袖，發明文字使溝通更方便，"]},{"code":401,"indent":1,"parameters":["並且具有強大的實力保衛村莊。"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["但他在與蚩尤大戰後便一蹶不振，"]},{"code":401,"indent":1,"parameters":["現在在村落郊區靜養。"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["有空再來找我聽故事喔"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"蚩尤"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["之前有個人叫做蚩尤，他是南蠻的王，"]},{"code":401,"indent":1,"parameters":["他擅長煉鐵製造器具，使得他的領民富裕。"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["但他性格好戰，多次與各地引起戰爭，"]},{"code":401,"indent":1,"parameters":["在與我們一次次的紛爭後敗逃至深山老林，"]},{"code":401,"indent":1,"parameters":["但他不甘心，再一次的向我們挑起征戰，"]},{"code":401,"indent":1,"parameters":["此為涿鹿之戰"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["這次他使出了渾身解數，請來風伯雨師，"]},{"code":401,"indent":1,"parameters":["帶著魑魅魍魎，局勢一邊倒的攻陷我們的村落，"]},{"code":401,"indent":1,"parameters":["直到黃帝發明出指南車奮力抵抗，將他再一次的擊退，"]},{"code":401,"indent":1,"parameters":["他又失敗了，但這次之後他不知所蹤，不知去了哪裡。"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["有空再來找我聽故事喔"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[2,"伏羲氏"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["我的夫君伏羲氏，他是我們村落的第一任首領，"]},{"code":401,"indent":1,"parameters":["他很聰明，能教我們結網捕魚、飼養牲畜，"]},{"code":401,"indent":1,"parameters":["使我們衣食無憂。還訂定婚姻制度，建立家庭觀念。"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["他在幾百年前傳位給炎帝後來到此地養殖牲畜，"]},{"code":401,"indent":1,"parameters":["與我過上悠閒幸福的生活。"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["有空再來找我聽故事喔"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[3,"神農氏"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["神農氏也叫做炎帝，是村莊的第二任領袖，"]},{"code":401,"indent":1,"parameters":["他為了村落的生計嚐遍百草，分辨出各類草藥的功用，"]},{"code":401,"indent":1,"parameters":["奠定了農業與藥學基礎。"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["他老了之後將領袖之位傳給黃帝，"]},{"code":401,"indent":1,"parameters":["現在在森林裡賣優質蘑菇。"]},{"code":126,"indent":1,"parameters":[49,0,0,1]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["獲得記憶碎片"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["有空再來找我聽故事喔"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[4,"女媧"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["我的故事要追溯到久遠以前天地剛形成之時，"]},{"code":401,"indent":1,"parameters":["遍地荒涼，只有滿山遍野的草木與廣闊無際的大海，"]},{"code":401,"indent":1,"parameters":["我覺得無聊便拿起泥土捏了幾個小人玩。"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["沒想到他們與我待久了居然形成靈智，"]},{"code":401,"indent":1,"parameters":["並且開始生長和我一樣高，"]},{"code":401,"indent":1,"parameters":["現在想起來還真是不可思議。"]},{"code":126,"indent":1,"parameters":[50,0,0,1]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["獲得記憶碎片"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["有空再來找我聽故事喔"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[5,"不用了"]},{"code":101,"indent":1,"parameters":["女媧 頭像",0,0,2,"女媧"]},{"code":401,"indent":1,"parameters":["好的，再見，有空再來找我聽故事喔"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":6,"y":6}
